# Copy this file to `.env` (which is gitignored) and fill in real values.
# These are read by docker-compose.yml via `env_file`. NEVER commit `.env`.

# HTTP listen port. Defaults to 8090. Change this if 8090 is already taken.
#REVERB_PORT=8090

# Directory spotDL downloads into AND the folder the bundled Navidrome serves.
# The Docker image defaults this to /music (bind-mounted from ./music), so you
# usually don't need to set it. Override only if you moved the mount point.
#REVERB_DOWNLOAD_DIR=/music

# Admin password seeded on first run if setup has not been completed yet.
# Leave blank to use the in-app first-run wizard instead. This is read ONLY on
# first run; once setup is complete it is ignored. Unset it after the first boot
# rather than leaving a plaintext password in your environment.
REVERB_ADMIN_PASSWORD=

# Spotify search adapter — your Spotify app's credentials.
# The Client ID is non-secret; you can set it here or in the in-app Settings UI.
#REVERB_SPOTIFY_CLIENT_ID=
REVERB_SPOTIFY_CLIENT_SECRET=

# Subsonic/Navidrome library adapter password (overrides the stored config_json
# secret at runtime). Set this if you point Reverb at an existing Navidrome.
REVERB_LIBRARY_PASSWORD=
