# Optional settings for docker-compose.yml. Copy to .env only if you need to
# change one; .env is gitignored and must never be committed.

# Pin a release instead of following latest.
#REVERB_VERSION=0.1.0

# Use an existing music folder. By default Reverb uses ./music beside this
# compose file and downloads there.
#REVERB_MUSIC_DIR=/srv/music

# Optional: skip the first-run password screen. Used only on the first boot;
# remove it from .env afterward.
#REVERB_ADMIN_PASSWORD=

# Optional Spotify catalog credentials.
#REVERB_SPOTIFY_CLIENT_ID=
#REVERB_SPOTIFY_CLIENT_SECRET=

# Optional password for an external Subsonic/Navidrome library backend.
#REVERB_LIBRARY_PASSWORD=
